rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false; // Catch-all default deny
    }

    // Global helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function existing() { return resource.data; }
    function incoming() { return request.resource.data; }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User's Items
    match /users/{userId}/items/{itemId} {
      function isValidItem(data) {
        return data.keys().hasAll(['userId', 'photoUrl', 'garmentType', 'color', 'timesWorn', 'status', 'createdAt'])
            && data.userId == userId
            && data.photoUrl is string && data.photoUrl.size() <= 2048
            && data.garmentType is string && data.garmentType.size() <= 100
            && data.color is string && data.color.size() <= 100
            && data.timesWorn is number
            && data.status is string && data.status.size() <= 50
            && data.createdAt is timestamp;
      }

      allow read: if isOwner(userId) && existing().userId == userId;

      allow create: if isOwner(userId)
                    && isValidId(userId)
                    && isValidId(itemId)
                    && isValidItem(incoming())
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time;

      allow update: if isOwner(userId)
                    && isValidId(userId)
                    && isValidId(itemId)
                    && existing().userId == userId
                    && isValidItem(incoming())
                    && incoming().userId == existing().userId
                    && incoming().createdAt == existing().createdAt
                    && incoming().updatedAt == request.time;

      allow delete: if isOwner(userId) && isValidId(userId) && isValidId(itemId) && existing().userId == userId;
      
      allow list: if isOwner(userId) && existing().userId == userId;
    }

    // User's Looks
    match /users/{userId}/looks/{lookId} {
      function isValidLook(data) {
        return data.keys().hasAll(['userId', 'name', 'itemIds', 'createdAt'])
            && data.userId == userId
            && data.name is string && data.name.size() <= 100
            && data.itemIds is list && data.itemIds.size() <= 50
            && data.createdAt is timestamp;
      }

      allow read: if isOwner(userId) && existing().userId == userId;

      allow create: if isOwner(userId)
                    && isValidId(userId)
                    && isValidId(lookId)
                    && isValidLook(incoming())
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time;

      allow update: if isOwner(userId)
                    && isValidId(userId)
                    && isValidId(lookId)
                    && existing().userId == userId
                    && isValidLook(incoming())
                    && incoming().userId == existing().userId
                    && incoming().createdAt == existing().createdAt
                    && incoming().updatedAt == request.time;

      allow delete: if isOwner(userId) && isValidId(userId) && isValidId(lookId) && existing().userId == userId;
      
      allow list: if isOwner(userId) && existing().userId == userId;
    }

    // User's WearLogs
    match /users/{userId}/wearLogs/{wearLogId} {
      function isValidWearLog(data) {
        return data.keys().hasAll(['userId', 'targetId', 'targetType', 'date', 'createdAt'])
            && data.userId == userId
            && data.targetId is string && data.targetId.size() <= 128
            && data.targetType is string && (data.targetType == 'items' || data.targetType == 'looks')
            && data.date is timestamp
            && data.createdAt is timestamp;
      }

      allow read: if isOwner(userId) && existing().userId == userId;

      allow create: if isOwner(userId)
                    && isValidId(userId)
                    && isValidId(wearLogId)
                    && isValidWearLog(incoming())
                    && incoming().createdAt == request.time;

      allow delete: if isOwner(userId) && isValidId(userId) && isValidId(wearLogId) && existing().userId == userId;
      
      allow list: if isOwner(userId) && existing().userId == userId;
    }
  }
}
